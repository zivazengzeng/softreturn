{
  "name": "fresh-manmanhuilai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5188",
    "build": "tsc -b && vite build",
    "ios:assets": "node scripts/generate-ios-assets.mjs",
    "ios:add": "cap add ios",
    "ios:sync": "npm run ios:assets && npm run build && cap sync ios",
    "ios:open": "cap open ios",
    "ios:run": "npm run ios:sync && cap run ios"
  },
  "dependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.5",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
